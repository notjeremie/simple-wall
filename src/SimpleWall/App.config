<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Do NOT add a <configSections> declaration for the section below. On .NET Framework
    4.7+ System.Windows.Forms.ApplicationConfigurationSection is BUILT IN, and declaring
    it yourself is a hard error: "the section is a built-in section, it cannot be
    declared by the user". That takes down the whole configuration system, so the very
    first ConfigurationManager read throws and the app dies at startup reporting
    "Configuration system failed to initialize". It shipped that way on 2026-07-20.
    AppConfigTests guards it.

    This file exists to opt WinForms into per-monitor DPI. The manifest alone makes the
    PROCESS per-monitor aware (so Screen bounds are honest and the output window lands
    correctly) but leaves the WinForms controls unresponsive to a DPI change. Both are
    needed; see src/SimpleWall/app.manifest for the full reasoning.
  -->
  <System.Windows.Forms.ApplicationConfigurationSection>
    <add key="DpiAwareness" value="PerMonitorV2" />
  </System.Windows.Forms.ApplicationConfigurationSection>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
</configuration>
